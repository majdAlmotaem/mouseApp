<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Main App Theme -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/status_bar_color</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">@color/status_bar_color</item>
    </style>

    <!-- Futuristic Button Style -->
    <style name="RemoteButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/remote_button</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">2dp</item>
        <item name="strokeColor">@color/button_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/button_ripple</item>
        <item name="android:hapticFeedbackEnabled">true</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Volume Control Button Style -->
    <style name="VolumeButtonStyle" parent="RemoteButtonStyle">
        <item name="backgroundTint">@color/remote_button</item>
        <item name="strokeColor">@color/button_stroke</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Power Button Style (Futuristic Glow) -->
    <style name="PowerButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/background_dark</item>
        <item name="android:textColor">@color/power_button</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/power_button</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="rippleColor">@color/power_button_ripple</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Navigation Button Style -->
    <style name="NavigationButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/accent_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/button_ripple</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Card Style -->
    <style name="FuturisticCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/button_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="FuturisticDialogStyle" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/card_background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogButtonStyle</item>
    </style>

    <style name="DialogButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/colorAccent</item>
    </style>

</resources>